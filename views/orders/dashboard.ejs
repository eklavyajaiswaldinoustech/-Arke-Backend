<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Orders Dashboard</title>
  <link rel="stylesheet" href="/admin/css/admin.css">
  <style>
    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      margin-bottom: 32px;
    }
    .stat-card {
      background: linear-gradient(135deg, rgba(168,85,247,0.1), rgba(232,180,196,0.08));
      border: 1.5px solid rgba(232,180,196,0.3);
      border-radius: 12px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
    }
    .stat-card:hover {
      transform: translateY(-4px);
      border-color: rgba(139,70,84,0.4);
      box-shadow: 0 8px 24px rgba(232,180,196,0.15);
    }
    .stat-value {
      font-size: 32px;
      font-weight: 700;
      color: #8b4654;
      font-family: 'Poppins', sans-serif;
    }
    .stat-label {
      font-size: 12px;
      color: #8a8a8a;
      font-family: 'Poppins', sans-serif;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
  </style>
</head>
<body>
<%- include('../layouts/main') %>

<div style="padding: 32px 80px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
    <h1 style="margin: 0; font-size: 32px; color: #2a2a2a; font-family: 'Cormorant Garamond', serif;">
      📊 Order Dashboard
    </h1>
    <a href="/admin/orders" class="btn btn-secondary">View All Orders →</a>
  </div>

  <!-- Stats -->
  <div class="dashboard-grid">
    <div class="stat-card">
      <div class="stat-value"><%= stats.todayOrders || 0 %></div>
      <div class="stat-label">Today's Orders</div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= stats.pendingOrders || 0 %></div>
      <div class="stat-label">Pending Processing</div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= stats.shippedOrders || 0 %></div>
      <div class="stat-label">In Transit</div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= stats.deliveredOrders || 0 %></div>
      <div class="stat-label">Delivered</div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= stats.returnRequests || 0 %></div>
      <div class="stat-label">Return Requests</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">₹<%= (stats.totalRevenue || 0).toLocaleString('en-IN') %></div>
      <div class="stat-label">Total Revenue</div>
    </div>
  </div>

  <!-- Recent Orders -->
  <div style="background: white; border: 1.5px solid #e8ddd4; border-radius: 12px; padding: 28px; margin-bottom: 32px;">
    <h2 style="margin: 0 0 20px 0; font-size: 20px; color: #2a2a2a; font-family: 'Cormorant Garamond', serif;">
      Recent Orders
    </h2>
    
    <% if (recentOrders && recentOrders.length > 0) { %>
      <table style="width: 100%; border-collapse: collapse;">
        <thead>
          <tr style="border-bottom: 2px solid #f0ebe5;">
            <th style="text-align: left; padding: 12px 8px; font-weight: 600; color: #8a8a8a; font-size: 12px;">Order ID</th>
            <th style="text-align: left; padding: 12px 8px; font-weight: 600; color: #8a8a8a; font-size: 12px;">Customer</th>
            <th style="text-align: left; padding: 12px 8px; font-weight: 600; color: #8a8a8a; font-size: 12px;">Amount</th>
            <th style="text-align: left; padding: 12px 8px; font-weight: 600; color: #8a8a8a; font-size: 12px;">Status</th>
            <th style="text-align: left; padding: 12px 8px; font-weight: 600; color: #8a8a8a; font-size: 12px;">Date</th>
            <th style="text-align: left; padding: 12px 8px; font-weight: 600; color: #8a8a8a; font-size: 12px;">Action</th>
          </tr>
        </thead>
        <tbody>
          <% recentOrders.forEach(order => { %>
            <tr style="border-bottom: 1px solid #f0ebe5; transition: all 0.3s;">
              <td style="padding: 12px 8px; font-weight: 600; color: #8b4654;">
                <%= order.orderId %>
              </td>
              <td style="padding: 12px 8px; color: #2a2a2a;">
                <%= order.userId?.name || 'N/A' %>
              </td>
              <td style="padding: 12px 8px; font-weight: 600; color: #2a2a2a;">
                ₹<%= order.total?.toLocaleString('en-IN') %>
              </td>
              <td style="padding: 12px 8px;">
                <span style="display: inline-block; padding: 4px 12px; border-radius: 12px; font-size: 11px; font-weight: 600;
                  <% if (order.status === 'delivered') { %>
                    background: rgba(112,200,120,0.15); color: #70c878;
                  <% } else if (['shipped', 'in_transit'].includes(order.status)) { %>
                    background: rgba(232,168,76,0.15); color: #e8a84c;
                  <% } else if (order.status === 'cancelled') { %>
                    background: rgba(217,112,112,0.15); color: #d97070;
                  <% } else { %>
                    background: rgba(91,155,213,0.15); color: #5b9bd5;
                  <% } %>">
                  <%= order.status.replace(/_/g, ' ').toUpperCase() %>
                </span>
              </td>
              <td style="padding: 12px 8px; font-size: 12px; color: #8a8a8a;">
                <%= new Date(order.createdAt).toLocaleDateString('en-IN') %>
              </td>
              <td style="padding: 12px 8px;">
                <a href="/admin/orders/<%= order._id %>/detail" style="color: #8b4654; text-decoration: none; font-weight: 600; font-size: 12px;">
                  View →
                </a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } else { %>
      <p style="text-align: center; color: #8a8a8a; padding: 40px 0;">No orders yet</p>
    <% } %>
  </div>
</div>

</body>
</html>
