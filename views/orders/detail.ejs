<div class="page-header">
  <div>
    <h1 class="page-title">Order #<%= (order._id+'').slice(-8).toUpperCase() %></h1>
    <p class="page-sub">Placed on <%= new Date(order.createdAt).toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'long',year:'numeric'}) %></p>
  </div>
  <a href="/admin/orders" class="btn btn-ghost">← All Orders</a>
</div>

<div class="order-grid">
  <!-- Left: Items + Timeline -->
  <div>
    <!-- Update Status -->
    <div class="card">
      <div class="card-header"><span class="card-title">Update Order Status</span></div>
      <div class="card-body">
        <form method="POST" action="/admin/orders/<%= order._id %>/status" style="display:flex; gap:12px; align-items:flex-end;">
          <div class="field" style="flex:1; margin-bottom:0">
            <label>Order Status</label>
            <select name="status">
              <% ['placed','confirmed','processing','packed','shipped','in_transit','out_for_delivery','delivered','cancelled'].forEach(s => { %>
              <option value="<%= s %>" <%= order.status===s ? 'selected':'' %>><%= s.replace(/_/g, ' ').toUpperCase() %></option>
              <% }); %>
            </select>
          </div>
          <div class="field" style="flex:1; margin-bottom:0">
            <label>Payment Status</label>
            <select name="paymentStatus">
              <% ['pending','paid','failed','refunded'].forEach(s => { %>
              <option value="<%= s %>" <%= order.paymentStatus===s ? 'selected':'' %>><%= s.charAt(0).toUpperCase()+s.slice(1) %></option>
              <% }); %>
            </select>
          </div>
          <button type="submit" class="btn btn-primary" style="flex-shrink:0;">Update</button>
        </form>
      </div>
    </div>

    <!-- Order Items -->
    <div class="card">
      <div class="card-header"><span class="card-title">Order Items</span></div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Product</th><th>Price</th><th>Qty</th><th>Total</th></tr></thead>
          <tbody>
            <% if (order.items && order.items.length > 0) { %>
              <% order.items.forEach(item => { %>
              <% const prod = item.productId || item.product || {}; %>
              <tr>
                <td style="display:flex; align-items:center; gap:12px; padding:12px 16px;">
                  <% const imgUrl = item.image || (prod.images && prod.images[0]); %>
                  <% if (imgUrl) { %>
                    <img src="<%= imgUrl %>" class="thumb" />
                  <% } else { %>
                    <div class="thumb-placeholder">◇</div>
                  <% } %>
                  <div>
                    <div style="color:var(--text);"><%= prod.name || item.name || '—' %></div>
                    <div style="font-size:11px; color:var(--text3);">SKU: <%= prod.sku || '—' %></div>
                  </div>
                </td>
                <td>₹<%= (item.price||0).toLocaleString() %></td>
                <td><%= item.quantity || 1 %></td>
                <td style="color:var(--gold);">₹<%= ((item.price||0)*(item.quantity||1)).toLocaleString() %></td>
              </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Shipping Address -->
    <% if (order.shippingAddress) { %>
    <div class="card">
      <div class="card-header"><span class="card-title">Shipping Address</span></div>
      <div class="card-body" style="font-size:13px; color:var(--text2); line-height:1.9;">
        <div style="color:var(--text); font-weight:500; margin-bottom:4px;"><%= order.shippingAddress.name || '' %></div>
        <div><%= order.shippingAddress.line1 || '' %></div>
        <% if (order.shippingAddress.line2) { %><div><%= order.shippingAddress.line2 %></div><% } %>
        <div><%= [order.shippingAddress.city, order.shippingAddress.state, order.shippingAddress.pincode].filter(Boolean).join(', ') %></div>
        <% if (order.shippingAddress.phone) { %><div style="color:var(--text3); margin-top:4px;">📞 <%= order.shippingAddress.phone %></div><% } %>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Right: Summary -->
  <div>
    <div class="card">
      <div class="card-header"><span class="card-title">Order Summary</span></div>
      <div class="card-body">
        <div class="detail-row"><span class="detail-label">Subtotal</span><span class="detail-val">₹<%= (order.subtotal||order.total||0).toLocaleString() %></span></div>
        <div class="detail-row"><span class="detail-label">Shipping</span><span class="detail-val"><%= order.shippingCost ? '₹'+order.shippingCost : 'Free' %></span></div>
        <% if (order.discount) { %>
        <div class="detail-row"><span class="detail-label">Discount</span><span class="detail-val" style="color:var(--green);">−₹<%= order.discount.toLocaleString() %></span></div>
        <% } %>
        <div class="detail-row" style="border:none; margin-top:8px; padding-top:12px; border-top:1px solid var(--border);">
          <span style="font-family:'Cormorant Garamond',serif; font-size:18px; color:var(--text);">Total</span>
          <span style="font-family:'Cormorant Garamond',serif; font-size:22px; color:var(--gold);">₹<%= (order.total||0).toLocaleString() %></span>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><span class="card-title">Customer</span></div>
      <div class="card-body" style="font-size:13px;">
        <% const u = order.userId || {}; %>
        <div style="color:var(--text); font-weight:500; margin-bottom:6px;"><%= u.name || '—' %></div>
        <div style="color:var(--text3); margin-bottom:4px;"><%= u.email || '—' %></div>
        <div style="color:var(--text3);">📞 <%= u.phone || '—' %></div>
        <% if (u._id) { %>
        <a href="/admin/users/<%= u._id %>" class="btn btn-ghost btn-sm" style="margin-top:12px;">View Profile</a>
        <% } %>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><span class="card-title">Payment</span></div>
      <div class="card-body" style="font-size:13px;">
        <div class="detail-row"><span class="detail-label">Method</span><span class="detail-val"><%= order.paymentMethod || 'Online' %></span></div>
        <div class="detail-row"><span class="detail-label">Status</span>
          <span class="badge <%= order.paymentStatus==='paid' ? 'badge-green' : 'badge-gold' %>"><%= order.paymentStatus || 'pending' %></span>
        </div>
        <% if (order.razorpayOrderId) { %>
        <div class="detail-row"><span class="detail-label">Razorpay ID</span><span class="detail-val" style="font-size:11px; word-break:break-all;"><%= order.razorpayOrderId %></span></div>
        <% } %>
      </div>
    </div>
  </div>
</div>
