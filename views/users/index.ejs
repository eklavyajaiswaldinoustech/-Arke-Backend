<div class="page-header">
  <div>
    <h1 class="page-title">Customers</h1>
    <p class="page-sub"><%= users.length %> registered customers</p>
  </div>
  <div style="font-size:11px; color:var(--text3); letter-spacing:1px; padding:10px 20px; border:1px solid var(--border2);">
    Total: <%= users.length %>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card compact">
    <div class="stat-icon">◷</div>
    <div class="stat-value"><%= users.length %></div>
    <div class="stat-label">Total Customers</div>
  </div>
  <div class="stat-card compact">
    <div class="stat-icon" style="color:var(--success)">✓</div>
    <div class="stat-value"><%= users.filter(u => u.isActive !== false).length %></div>
    <div class="stat-label">Active</div>
  </div>
  <div class="stat-card compact">
    <div class="stat-icon" style="color:var(--danger)">!</div>
    <div class="stat-value"><%= users.filter(u => u.isActive === false).length %></div>
    <div class="stat-label">Blocked</div>
  </div>
  <div class="stat-card compact">
    <div class="stat-icon" style="color:var(--warning)">₹</div>
    <div class="stat-value">₹<%= users.reduce((sum,u)=>sum+(u.totalSpent||0),0).toLocaleString() %></div>
    <div class="stat-label">Customer Spend</div>
  </div>
</div>

<div class="filter-bar">
  <div class="search-box" style="max-width:300px;">
    <input type="text" id="tableSearch" placeholder="Search by name or email…" />
  </div>
  <select class="filter-select" data-filter-column="7">
    <option value="">All Status</option>
    <option value="Active">Active</option>
    <option value="Blocked">Blocked</option>
  </select>
</div>

<div class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Orders</th>
          <th>Total Spent</th>
          <th>Joined</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (users.length > 0) { %>
          <% users.forEach((u, i) => { %>
          <tr>
            <td style="color:var(--text3); font-size:11px;"><%= i+1 %></td>
            <td>
              <div style="display:flex; align-items:center; gap:10px;">
                <div style="width:32px; height:32px; border-radius:50%; background:rgba(184,151,63,0.1); border:1px solid rgba(184,151,63,0.2); display:flex; align-items:center; justify-content:center; font-size:13px; color:var(--gold); flex-shrink:0; text-transform:uppercase;">
                  <%= (u.name||'?')[0] %>
                </div>
                <span style="color:var(--text);"><%= u.name || '—' %></span>
              </div>
            </td>
            <td style="color:var(--text3);"><%= u.email %></td>
            <td style="color:var(--text3); font-size:12px;"><%= u.phone || '—' %></td>
            <td><span class="badge badge-gray"><%= u.orderCount || 0 %></span></td>
            <td style="color:var(--gold);">₹<%= (u.totalSpent||0).toLocaleString() %></td>
            <td style="color:var(--text3); font-size:12px;"><%= new Date(u.createdAt).toLocaleDateString('en-IN') %></td>
            <td><span class="badge <%= u.isActive!==false ? 'badge-green' : 'badge-red' %>"><%= u.isActive!==false ? 'Active' : 'Blocked' %></span></td>
            <td>
              <div style="display:flex; gap:6px;">
                <a href="/admin/users/<%= u._id %>" class="btn btn-primary btn-sm">View</a>
                <a href="/admin/users/<%= u._id %>/toggle" class="btn btn-danger btn-sm"
                   data-confirm="<%= u.isActive!==false ? 'Block this user?' : 'Unblock this user?' %>">
                  <%= u.isActive!==false ? 'Block' : 'Unblock' %>
                </a>
              </div>
            </td>
          </tr>
          <% }); %>
        <% } else { %>
        <tr><td colspan="9" style="text-align:center;padding:60px;color:var(--text3);">No customers yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
