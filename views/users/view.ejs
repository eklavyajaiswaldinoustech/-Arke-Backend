<div class="page-header">
  <div>
    <h1 class="page-title"><%= user.name || 'Customer' %></h1>
    <p class="page-sub"><%= user.email %> · joined <%= new Date(user.createdAt).toLocaleDateString('en-IN') %></p>
  </div>
  <div style="display:flex;gap:8px;align-items:center;">
    <a href="/admin/users" class="btn btn-ghost">Back</a>
    <a href="/admin/users/<%= user._id %>/toggle" class="btn <%= user.isActive!==false ? 'btn-danger' : 'btn-primary' %>"
       data-confirm="<%= user.isActive!==false ? 'Block this customer?' : 'Unblock this customer?' %>">
      <%= user.isActive!==false ? 'Block Customer' : 'Unblock Customer' %>
    </a>
  </div>
</div>

<div class="profile-hero">
  <div class="profile-avatar"><%= (user.name || user.email || '?')[0] %></div>
  <div class="profile-main">
    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
      <h2><%= user.name || 'Unnamed Customer' %></h2>
      <span class="badge <%= user.isActive!==false ? 'badge-green' : 'badge-red' %>"><%= user.isActive!==false ? 'Active' : 'Blocked' %></span>
      <% if (user.isVerified) { %><span class="badge badge-blue">Verified</span><% } %>
    </div>
    <div class="profile-meta">
      <span><%= user.email %></span>
      <span><%= user.phone || 'No phone added' %></span>
      <span>ID: <%= user._id %></span>
    </div>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card compact">
    <div class="stat-icon">◎</div>
    <div class="stat-value"><%= stats.totalOrders %></div>
    <div class="stat-label">Orders</div>
  </div>
  <div class="stat-card compact">
    <div class="stat-icon" style="color:var(--success)">₹</div>
    <div class="stat-value">₹<%= stats.totalSpent.toLocaleString() %></div>
    <div class="stat-label">Paid Spend</div>
  </div>
  <div class="stat-card compact">
    <div class="stat-icon" style="color:var(--warning)">◒</div>
    <div class="stat-value">₹<%= stats.averageOrderValue.toLocaleString() %></div>
    <div class="stat-label">Avg Order</div>
  </div>
  <div class="stat-card compact">
    <div class="stat-icon" style="color:var(--accent)">◷</div>
    <div class="stat-value"><%= stats.pendingOrders %></div>
    <div class="stat-label">Open Orders</div>
  </div>
</div>

<div class="detail-layout">
  <div>
    <div class="card">
      <div class="card-header">
        <span class="card-title">Recent Orders</span>
        <a href="/admin/orders" class="btn btn-ghost btn-sm">All Orders</a>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Order</th>
              <th>Items</th>
              <th>Amount</th>
              <th>Payment</th>
              <th>Status</th>
              <th>Date</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (orders.length) { %>
              <% orders.forEach(order => { %>
              <tr>
                <td style="color:var(--gold);">#<%= (order._id+'').slice(-8).toUpperCase() %></td>
                <td><%= order.items ? order.items.length : 0 %> items</td>
                <td style="color:var(--text);">₹<%= (order.totalAmount || 0).toLocaleString() %></td>
                <td><span class="badge <%= order.paymentStatus==='paid' ? 'badge-green' : 'badge-gold' %>"><%= order.paymentStatus || 'pending' %></span></td>
                <td>
                  <% const sc = {pending:'badge-gold',processing:'badge-blue',shipped:'badge-blue',delivered:'badge-green',cancelled:'badge-red'}; %>
                  <span class="badge <%= sc[order.status] || 'badge-gray' %>"><%= order.status || 'pending' %></span>
                </td>
                <td style="color:var(--text3);"><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></td>
                <td><a href="/admin/orders/<%= order._id %>" class="btn btn-ghost btn-sm">View</a></td>
              </tr>
              <% }); %>
            <% } else { %>
              <tr><td colspan="7" style="text-align:center;padding:48px;color:var(--text3);">No orders from this customer yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <aside>
    <div class="card">
      <div class="card-header"><span class="card-title">Contact</span></div>
      <div class="card-body">
        <div class="detail-row"><span class="detail-label">Email</span><span class="detail-val"><%= user.email %></span></div>
        <div class="detail-row"><span class="detail-label">Phone</span><span class="detail-val"><%= user.phone || '—' %></span></div>
        <div class="detail-row"><span class="detail-label">Status</span><span class="detail-val"><%= user.isActive!==false ? 'Active' : 'Blocked' %></span></div>
        <div class="detail-row"><span class="detail-label">Registered</span><span class="detail-val"><%= new Date(user.createdAt).toLocaleString('en-IN') %></span></div>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><span class="card-title">Bank Details</span></div>
      <div class="card-body">
        <% if (bankDetails) { %>
          <div class="detail-row"><span class="detail-label">Bank</span><span class="detail-val"><%= bankDetails.bankName %></span></div>
          <div class="detail-row"><span class="detail-label">Holder</span><span class="detail-val"><%= bankDetails.accountHolderName %></span></div>
          <div class="detail-row"><span class="detail-label">IFSC</span><span class="detail-val"><%= bankDetails.ifscCode %></span></div>
          <div class="detail-row"><span class="detail-label">Verified</span><span class="detail-val"><%= bankDetails.isVerified ? 'Yes' : 'No' %></span></div>
          <a href="/admin/bank-details/view/<%= bankDetails._id %>" class="btn btn-ghost btn-sm" style="margin-top:14px;">View Bank Record</a>
        <% } else { %>
          <p style="color:var(--text3);font-size:13px;">No bank details saved.</p>
        <% } %>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><span class="card-title">Addresses</span></div>
      <div class="card-body">
        <% if (user.addresses && user.addresses.length) { %>
          <% user.addresses.forEach(address => { %>
            <div class="address-block">
              <div style="color:var(--text);font-weight:500;"><%= address.label || 'Address' %> <% if (address.isDefault) { %><span class="badge badge-blue">Default</span><% } %></div>
              <div><%= address.name || user.name || '' %></div>
              <div><%= address.line1 || '' %> <%= address.line2 || '' %></div>
              <div><%= [address.city, address.state, address.pincode].filter(Boolean).join(', ') %></div>
              <div><%= address.phone || '' %></div>
            </div>
          <% }); %>
        <% } else { %>
          <p style="color:var(--text3);font-size:13px;">No saved addresses.</p>
        <% } %>
      </div>
    </div>
  </aside>
</div>
